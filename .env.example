# Required: create a restricted key with Text to Speech + Voices read access.
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Required: a long random value used inside the private MCP URL.
MCP_PATH_SECRET=replace_with_a_long_random_secret

# Optional: used when generate_speech does not receive a voice_id.
ELEVENLABS_VOICE_ID=

# Optional defaults and operational limits.
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
MAX_TEXT_LENGTH=5000
AUDIO_TTL_SECONDS=900
MAX_CACHED_AUDIO_BYTES=52428800
MAX_GENERATIONS_PER_MINUTE=10
MAX_CONCURRENT_GENERATIONS=2

# Optional outside Railway: choose where to persist the preferred voice.
# Railway volumes are detected automatically through RAILWAY_VOLUME_MOUNT_PATH.
# Without persistent storage, the preference still works but may be lost when the container is replaced.
# DATA_DIR=/data
PORT=3000

