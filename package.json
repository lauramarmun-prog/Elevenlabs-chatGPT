{
  "name": "elevenlabs-chatgpt-mcp",
  "version": "0.2.5",
  "description": "A self-hosted ElevenLabs text-to-speech MCP app for ChatGPT, ready for Railway.",
  "type": "module",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "predev": "npm run build:widget",
    "dev": "node --env-file-if-exists=.env --import tsx src/server.ts",
    "build:widget": "node scripts/build-widget.mjs",
    "build": "tsc -p tsconfig.json && npm run build:widget",
    "start": "node dist/server.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node tests/smoke.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  },
  "overrides": {
    "fast-uri": "3.1.4"
  }
}
